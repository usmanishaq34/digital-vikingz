# Digital Vikingz CMS — Supabase / Postgres setup
# Use Supabase Project Settings > Database > Connection string.
# DATABASE_URL should usually use Supabase pooled connection on port 6543 for app runtime.
# DIRECT_URL should usually use direct connection on port 5432 for Prisma migrations/db push.

DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# Public site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# First admin user used by prisma/seed.ts
ADMIN_EMAIL="admin@digitalvikingz.com"
ADMIN_PASSWORD="ChangeThisStrongPassword123!"
ADMIN_NAME="Digital Vikingz Admin"

# Optional: Supabase Storage for media uploads
# Create a public/private bucket in Supabase Storage and add these values.
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key-server-only"
SUPABASE_STORAGE_BUCKET="digital-vikingz-media"
AUTH_SECRET="same-value-as-NEXTAUTH_SECRET"
